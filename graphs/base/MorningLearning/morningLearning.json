    {
      "id": "llm-mn16a94w",
      "name": "Topic Chooser",
      "type": "llm",
      "position": {
        "x": -272.4839259576628,
        "y": -120.13247220634005
      },
      "promptTemplate": "suggest an interesting topic to begin the users day with. The topics do not need to be related to any of the previous topics. Do not suggest topics which have been suggested previously\n\n<previous topics>\n{{read-file.output}}\n</previous topics>",
      "temperature": 0.15,
      "model": "nvidia/nemotron-nano-9b-v2:free",
      "provider": "openrouter",
      "systemPrompt": "You are a research agent. Your task is to suggest a single topic for a user to begin their day with. The topic suggested will be used to find wikipedia articles that will be the basis of further research.\n\n<limitations>\nDo not suggest topics which have previously been suggested\n</limitations>\n\n<output>\noutput must be in the following json format {\"topic\" : $topic}\ndo not output anything besides this json\n</output>",
      "maxTokens": 500,
      "outputKey": "topic"
    },
    {
      "id": "tool-mn16nfuy",
      "name": "Wiki Search",
      "type": "tool",
      "position": {
        "x": 76.84118540634849,
        "y": -153.896237616988
      },
      "model": "gpt-4o",
      "toolName": "base/wiki-search",
      "toolInput": {
        "query": "{{topic.output.topic}}"
      },
      "outputKey": "wiki"
    },
    {
      "id": "llm-mn16phiu",
      "name": "Summarize",
      "type": "llm",
      "position": {
        "x": -14.061259930011289,
        "y": 57.776599380535586
      },
      "promptTemplate": "Provide a distilled version of the information provided in the search section\n\nensure the summary gives enough information that a user with only surface level exposure to the topic could understand the topic after reading the summary. strive to keep the summary to 3 paragraphs maximum\n\n<search>\n{{wiki.output}}\n</search>",
      "temperature": 0.3,
      "model": "nvidia/nemotron-3-super-120b-a12b:free",
      "provider": "openrouter",
      "systemPrompt": "You are a research analyst tasked with providing a concise summary to the user",
      "outputKey": "summary"
    },
